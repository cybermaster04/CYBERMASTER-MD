{
  "name": "cybermaster-md",
  "description": "cybermaster-md, your powerful WhatsApp AI assistant!",
  "logo": "https://files.catbox.moe/tdiasl.jpg",
  "keywords": ["whatsapp-bot", "ai", "zimbabwe", "shona", "baileys", "md-bot"],
  "repository": "https://github.com/cybermaster04/CYBERMASTER-MD.git",
  "stack": "container",
  "addons": [
    {
      "plan": "heroku-postgresql"
    }
  ],
  "scripts": {
    "start": "node index.js"
  },
  "env": {
    "SESSION_ID": {
      "description": "Must begin with 'XHYPHER:~'. Get your session from the bot website.",
      "value": "",
      "required": true
    },
    "PREFIX": {
      "description": "Bot command prefix. Default is .",
      "value": ".",
      "required": false
    },
    "BOT_NAME": {
      "description": "Your bot name shown in menu",
      "value": "CYBERMASTER-MD",
      "required": false
    },
    "OWNER_NUMBER": {
      "description": "Your WhatsApp number with country code, e.g 2637xxxxxxx",
      "value": "",
      "required": true
    }
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "standard-2x"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    },
    {
      "url": "https://github.com/DuckyTeam/heroku-buildpack-imagemagick.git"
    },
    {
      "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest"
    },
    {
      "url": "https://github.com/clhuang/heroku-buildpack-webp-binaries.git"
    }
  ]
}
