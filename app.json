{
  "name": "CYBERMASTER-MD",
  "description": "CYBERMASTER-MD, advanced multi-device WhatsApp bot powered by CYBERMASTER TECH",
  "logo": "https://i.ibb.co/vFJVQYG/CYBERMASTER-TECH.jpg",
  "keywords": ["whatsapp", "bot", "md", "ai", "cybermaster", "multi-device", "automation"],
  "repository": "https://github.com/cybermaster04/CYBERMASTER-MD",
  "stack": "container",
  "addons": [
    {
      "plan": "heroku-postgresql"
    }
  ],
  "scripts": {
    "start": "node index.js"
  },
  "env": {
    "SESSION_ID": {
      "description": "Must begin with 'CYBERMASTER:~'. Get it from https://cybermaster-pair.onrender.com",
      "value": "",
      "required": true
    },
    "PREFIX": {
      "description": "Bot command prefix",
      "value": ".",
      "required": false
    },
    "OWNER_NUMBER": {
      "description": "Your WhatsApp number with country code, e.g 2637xxxxxxx",
      "value": "",
      "required": true
    }
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    },
    {
      "url": "https://github.com/DuckyTeam/heroku-buildpack-imagemagick.git"
    },
    {
      "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest"
    },
    {
      "url": "https://github.com/clhuang/heroku-buildpack-webp-binaries.git"
    }
  ]
}
